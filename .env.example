# ============================================================================
# Copy to .env (root) for docker-compose, or to apps/api/.env for direct runs.
# ============================================================================

# Database -------------------------------------------------------------------
POSTGRES_USER=task
POSTGRES_PASSWORD=task
POSTGRES_DB=task_management
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgres://task:task@localhost:5432/task_management

# API ------------------------------------------------------------------------
API_PORT=3001
API_HOST=0.0.0.0
NODE_ENV=development

# JWT must be at least 32 chars in production. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-me-in-production-please-32-chars-min
JWT_EXPIRES_IN=7d
COOKIE_NAME=task_session
COOKIE_DOMAIN=
COOKIE_SECURE=false           # set to true behind HTTPS in production

# CORS — the deployed frontend origin (Vercel URL in production)
CORS_ORIGIN=http://localhost:3000

# Frontend (Next.js) ---------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:3001
